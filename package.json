{
  "name": "ng-smart-form-error-mapper",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build":         "ng-packagr -p projects/ng-smart-form-error-mapper/ng-package.json",
    "build:watch":   "ng-packagr -p projects/ng-smart-form-error-mapper/ng-package.json --watch",
    "test":          "jest --config jest.config.js",
    "demo:serve":    "npx http-server docs -p 4200 -o",
    "demo:build":    "cp dist/ng-smart-form-error-mapper-demo.html docs/index.html",
    "release:patch": "npm version patch --no-git-tag-version && npm run build",
    "release:minor": "npm version minor --no-git-tag-version && npm run build",
    "release:major": "npm version major --no-git-tag-version && npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@angular/compiler": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "ng-packagr": "^17.0.0",
    "typescript": "~5.2.0",
    "rxjs": "~7.8.0",
    "jest": "^29.0.0",
    "jest-preset-angular": "^14.0.0",
    "@types/jest": "^29.0.0",
    "http-server": "^14.0.0"
  }
}
